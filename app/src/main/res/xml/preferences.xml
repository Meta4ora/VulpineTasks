<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <!-- Внешний вид -->
    <PreferenceCategory
        android:key="appearance_category"
        android:title="Внешний вид">

        <SwitchPreferenceCompat
            android:key="dark_mode"
            android:title="Тёмная тема"
            android:summary="Включить тёмную тему приложения"
            android:defaultValue="false" />

        <ListPreference
            android:key="font_size"
            android:title="Размер шрифта"
            android:summary="Выберите размер шрифта в редакторе"
            android:entries="@array/font_size_entries"
            android:entryValues="@array/font_size_values"
            android:defaultValue="medium" />

        <SwitchPreferenceCompat
            android:key="line_numbers"
            android:title="Нумерация строк"
            android:summary="Показывать номера строк в редакторе"
            android:defaultValue="false" />

        <SwitchPreferenceCompat
            android:key="word_wrap"
            android:title="Перенос слов"
            android:summary="Переносить длинные слова на новую строку"
            android:defaultValue="true" />

    </PreferenceCategory>

    <!-- Редактирование -->
    <PreferenceCategory
        android:key="editor_category"
        android:title="Редактирование">

        <SwitchPreferenceCompat
            android:key="auto_save"
            android:title="Автосохранение"
            android:summary="Автоматически сохранять заметки при редактировании"
            android:defaultValue="true" />

        <EditTextPreference
            android:key="default_note_title"
            android:title="Заголовок по умолчанию"
            android:summary="Заголовок для новых заметок"
            android:defaultValue="Новая заметка"
            android:dialogTitle="Заголовок по умолчанию" />

    </PreferenceCategory>

    <!-- Синхронизация -->
    <PreferenceCategory
        android:key="sync_category"
        android:title="Синхронизация">

        <SwitchPreferenceCompat
            android:key="auto_sync"
            android:title="Автосинхронизация"
            android:summary="Автоматически синхронизировать заметки с сервером"
            android:defaultValue="true" />

        <Preference
            android:key="sync_now"
            android:title="Синхронизировать сейчас"
            android:summary="Выполнить ручную синхронизацию" />

    </PreferenceCategory>

    <!-- Информация -->
    <PreferenceCategory
        android:key="info_category"
        android:title="Информация">

        <Preference
            android:key="version"
            android:title="Версия приложения"
            android:summary="1.0.0" />

        <Preference
            android:key="about"
            android:title="О приложении"
            android:summary="VulpineNotes - заметки с поддержкой Markdown" />

    </PreferenceCategory>

</PreferenceScreen>